<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>智学优教 - 大学生家教O2O一站式服务平台</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }
        html, body {
            height: 100%;
        }
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }
        .bg-img {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            background: url('background.jpg') center center/cover no-repeat;
        }
        .bg-mask {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(255,255,255,0.75);
            z-index: 1;
        }
        .container {
            width: 100%;
            max-width: 380px;
            text-align: center;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }
        .logo {
            width: 100px;
            height: 100px;
            margin-bottom: 18px;
            border-radius: 14px;
            box-shadow: 0 3px 12px rgba(42,77,155,0.10);
        }
        .title {
            font-size: 24px;
            font-weight: bold;
            color: #2A4D9B;
            margin-bottom: 10px;
        }
        .subtitle {
            font-size: 15px;
            color: #3A3A3A;
            margin-bottom: 24px;
        }
        .login-box {
            background: rgba(255,255,255,0.95);
            padding: 28px 20px 18px 20px;
            border-radius: 12px;
            box-shadow: 0 6px 24px rgba(42,77,155,0.10);
        }
        .role-buttons {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 18px;
        }
        .role-button {
            padding: 9px 28px;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-size: 15px;
            transition: all 0.3s;
            background: #F0F4FF;
            color: #2A4D9B;
            font-weight: 500;
        }
        .role-button.active {
            background: #2A4D9B;
            color: #fff;
            box-shadow: 0 2px 8px rgba(42,77,155,0.10);
        }
        .role-button:not(.active):hover {
            background: #E3EAFD;
        }
        .form-group {
            margin-bottom: 18px;
            text-align: left;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #2A4D9B;
            font-size: 15px;
        }
        .form-group input {
            width: 100%;
            padding: 11px 10px;
            border: 1px solid #BFD2F6;
            border-radius: 6px;
            font-size: 15px;
            background: #F7FAFF;
            color: #2A4D9B;
            transition: border 0.2s;
        }
        .form-group input:focus {
            outline: none;
            border-color: #2A4D9B;
            box-shadow: 0 0 0 2px rgba(42,77,155,0.10);
        }
        .forgot-password {
            text-align: right;
            margin-bottom: 18px;
        }
        .forgot-password a {
            color: #2A4D9B;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s;
        }
        .forgot-password a:hover {
            color: #FFD600;
        }
        .login-button {
            width: 100%;
            padding: 13px;
            background: #2A4D9B;
            color: #fff;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 14px;
            box-shadow: 0 2px 8px rgba(42,77,155,0.10);
            transition: background 0.3s;
        }
        .login-button:hover {
            background: #1d3570;
        }
        .register-link {
            text-align: center;
        }
        .register-link a {
            color: #2A4D9B;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s;
        }
        .register-link a:hover {
            color: #FFD600;
        }
        .footer {
            margin-top: 18px;
            font-size: 12px;
            color: #666;
            z-index: 2;
            position: relative;
        }
        .footer a {
            color: #666;
            text-decoration: none;
            margin: 0 6px;
            transition: color 0.2s;
        }
        .footer a:hover {
            color: #2A4D9B;
        }
        @media (max-width: 500px) {
            .container {
                max-width: 98vw;
                padding: 0 2vw;
            }
            .login-box {
                padding: 12px 2vw 10px 2vw;
            }
        }
    </style>
</head>
<body>
    <div class="bg-img"></div>
    <div class="bg-mask"></div>
    <div class="container">
        <img src="logo.jpg" alt="智学优教" class="logo">
        <h1 class="title">智学优教</h1>
        <p class="subtitle">大学生家教O2O一站式服务平台</p>
        <div class="login-box">
            <div class="role-buttons">
                <button class="role-button active" onclick="switchRole(this, true)">我是学生</button>
                <button class="role-button" onclick="switchRole(this, false)">我是教师</button>
            </div>
            <form onsubmit="handleSubmit(event)">
                <div class="form-group">
                    <label for="username">手机号</label>
                    <input type="text" id="username" placeholder="请输入您的手机号" required>
                </div>
                <div class="form-group">
                    <label for="password">密码</label>
                    <input type="password" id="password" placeholder="请输入您的密码" required>
                </div>
                <div class="forgot-password">
                    <a href="forget_password.html">忘记密码？</a>
                </div>
                <button type="submit" class="login-button">登录</button>
                <div class="register-link">
                    <a href="register.html">注册账号</a>
                </div>
            </form>
        </div>
        <div class="footer">
            <a href="#">服务条款</a>
            <span>|</span>
            <a href="#">隐私政策</a>
        </div>
    </div>
    <script>
        let isStudent = true;
        function switchRole(button, student) {
            isStudent = student;
            document.querySelectorAll('.role-button').forEach(btn => {
                btn.classList.remove('active');
            });
            button.classList.add('active');
        }
        function handleSubmit(event) {
            event.preventDefault();
            var phone = document.getElementById('username').value.trim();
            var password = document.getElementById('password').value;
            var isStudent = document.querySelector('.role-button.active').textContent === '我是学生';
            var dbKey = isStudent ? 'students' : 'teachers';
            var users = JSON.parse(localStorage.getItem(dbKey) || '[]');
            var user = users.find(u => u.phone === phone && u.password === password);
            if (user) {
                if (isStudent) {
                    localStorage.setItem('currentStudent', JSON.stringify(user));
                    window.location.href = 'student_main.html';
                } else {
                    localStorage.setItem('currentTeacher', JSON.stringify(user));
                    window.location.href = 'teacher_main.html';
                }
            } else {
                alert('手机号或密码错误');
            }
        }
    </script>
</body>
</html> 